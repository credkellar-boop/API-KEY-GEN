package main

import (
	"crypto/rand"
	"crypto/sha256"
	"encoding/base64"
	"encoding/hex"
	"fmt"
)

// ApiKeyGen represents the generator instance
type ApiKeyGen struct {
	Prefix string
}

// KeyData holds both the raw key and the hashed version
type KeyData struct {
	RawKey string
	DBHash string
}

// NewApiKeyGen creates a new API-KEY-GEN instance
func NewApiKeyGen(prefix string) *ApiKeyGen {
	return &ApiKeyGen{Prefix: prefix}
}

// Generate creates a 256-bit API key and its SHA-256 hash
func (g *ApiKeyGen) Generate() (*KeyData, error) {
	// Generate the raw key
	bytes := make([]byte, 32)
	if _, err := rand.Read(bytes); err != nil {
		return nil, err
	}
	
	randomStr := base64.RawURLEncoding.EncodeToString(bytes)
	rawKey := g.Prefix + randomStr
	
	// Generate the hash to store in your database
	hash := sha256.Sum256([]byte(rawKey))
	dbHash := hex.EncodeToString(hash[:])
	
	return &KeyData{
		RawKey: rawKey,
		DBHash: dbHash,
	}, nil
}

// --- Example Usage ---
func main() {
	generator := NewApiKeyGen("sk_live_")
	
	newKeyData, err := generator.Generate()
	if err != nil {
		fmt.Println("Error generating key:", err)
		return
	}
	
	fmt.Println("--- API-KEY-GEN ---")
	fmt.Printf("Give this to the user: %s\n", newKeyData.RawKey)
	fmt.Printf("Save this to the DB:   %s\n", newKeyData.DBHash)
}
