const crypto = require('crypto');

class ApiKeyGen {
    /**
     * API-KEY-GEN: A secure API key generator and hasher.
     * @param {string} prefix - The prefix to append to the key (default: 'sk_live_')
     */
    constructor(prefix = 'sk_live_') {
        this.prefix = prefix;
    }

    /**
     * Generates a 256-bit API key and its SHA-256 hash.
     * @returns {Object} An object containing the rawKey and dbHash.
     */
    generate() {
        // Generate the raw key
        const randomBytes = crypto.randomBytes(32).toString('base64url');
        const rawKey = `${this.prefix}${randomBytes}`;
        
        // Generate the hash to store in your database
        const dbHash = crypto.createHash('sha256').update(rawKey).digest('hex');
        
        return { rawKey, dbHash };
    }
}

