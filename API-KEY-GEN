import secrets
import hashlib
import argparse

class ApiKeyGen:
    """API-KEY-GEN: A secure API key generator and hasher."""
    
    def __init__(self, prefix="sk_live_"):
        self.prefix = prefix

    def generate(self):
        """Generates a 256-bit API key and its SHA-256 hash for secure storage."""
        # Generate the raw key
        random_bytes = secrets.token_urlsafe(32)
        raw_key = f"{self.prefix}{random_bytes}"
        
        # Generate the hash to store in your database
        key_hash = hashlib.sha256(raw_key.encode()).hexdigest()
        
        return {
            "raw_key": raw_key,
            "db_hash": key_hash
        }

